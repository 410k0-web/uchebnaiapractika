@model IReadOnlyList<ProductListItemViewModel>

<section class="page-header-with-action">
    <div>
        <h1>Список продукции</h1>
        <p>Нажмите на кнопку редактирования, чтобы изменить карточку товара, или откройте список цехов.</p>
    </div>
    <a class="primary-button" asp-action="Create">Добавить продукт</a>
</section>

@if (Model.Count == 0)
{
    <section class="single-card">
        <p>В базе данных пока нет продукции.</p>
    </section>
}
else
{
    <section class="product-grid">
        @foreach (var item in Model)
        {
            <article class="product-card">
                <div class="product-card-top">
                    <span class="pill">@item.ProductTypeName</span>
                    <span class="time-badge">@item.TotalProductionHoursRounded ч</span>
                </div>

                <h2>@item.Name</h2>

                <dl class="details-list">
                    <div>
                        <dt>Артикул</dt>
                        <dd>@item.Article</dd>
                    </div>
                    <div>
                        <dt>Минимальная стоимость</dt>
                        <dd>@item.PartnerMinPrice.ToString("N2", CultureInfo.GetCultureInfo("ru-RU")) ₽</dd>
                    </div>
                    <div>
                        <dt>Основной материал</dt>
                        <dd>@item.MaterialTypeName</dd>
                    </div>
                </dl>

                <div class="card-actions">
                    <a class="secondary-button" asp-action="Edit" asp-route-id="@item.ProductId">Редактировать</a>
                    <a class="outline-button" asp-controller="Workshops" asp-action="Index" asp-route-productId="@item.ProductId">Цеха</a>
                </div>
            </article>
        }
    </section>
}
